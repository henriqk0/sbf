---
import { Image } from "astro:assets";
import sbfLogo from "../assets/Logo-SBF60-small_1.png";
import ifesLogo from "../assets/serra-vertical-cor.png";
import ufesLogo from "../assets/Logo_Ufes.png";
import govLogo from "../assets/Brasao_Governo.png";
import sbfEsLogo from "../assets/logo-sbf-es-novo.png";

const sponsors = [
  { name: "SBF - ES", type: "Apoio Regional", image: sbfEsLogo, alt: "logo_sbf_es" },
  { name: "Sociedade Brasileira de Física", type: "Apoio", image: sbfLogo, alt: "logo_sbf" },
  { name: "IFES", type: "Instituição Organizadora", image: ifesLogo, alt: "logo_ifes" },
  { name: "UFES", type: "Parceiro Institucional", image: ufesLogo, alt: "logo_ufes" },
  { name: "Governo do ES", type: "Apoio", image: govLogo, alt: "logo_goves" },
];
---

<footer class="py-12 bg-slate-50 border-t border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    
    <div class="text-center mb-10">
      <h3 class="text-slate-500 text-sm font-semibold uppercase tracking-wider">
        Parceiros e Apoiadores
      </h3>
    </div>

    {/* Força 5 colunas fixas em qualquer tamanho de tela e centraliza o conteúdo */}
    <div class="grid grid-cols-5 gap-4 sm:gap-8 items-center justify-items-center">
      {
        sponsors.map((sponsor) => (
          <div class="w-full flex justify-center" title={`${sponsor.name} - ${sponsor.type}`}>
            {}
            <Image 
              src={sponsor.image} 
              alt={sponsor.alt} 
              class="h-auto w-full max-h-24 object-contain" 
            />
          </div>
        ))
      }
    </div>
    
  </div>
</footer>