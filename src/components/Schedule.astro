// Compute unique types per day
const dayTypes = schedule.map((day) => {
  const types = new Set(day.activities.map((a) => a.type));
  return Array.from(types);
});

const typeConfig: Record<
  string,
  {
    icon: string;
    color: string;
    bg: string;
    borderColor: string;
    iconBg: string;
    label: string;
  }
> = {
  opening: {
    icon: "mic",
    color: "text-violet-700",
    bg: "bg-violet-50",
    borderColor: "border-l-violet-500",
    iconBg: "bg-violet-500",
    label: "Abertura",
  },
  talk: {
    icon: "mic",
    color: "text-blue-700",
    bg: "bg-blue-50",
    borderColor: "border-l-blue-500",
    iconBg: "bg-blue-500",
    label: "Palestra",
  },
  break: {
    icon: "coffee",
    color: "text-emerald-700",
    bg: "bg-emerald-50",
    borderColor: "border-l-emerald-500",
    iconBg: "bg-emerald-500",
    label: "Intervalo",
  },
  poster: {
    icon: "users",
    color: "text-cyan-700",
    bg: "bg-cyan-50",
    borderColor: "border-l-cyan-500",
    iconBg: "bg-cyan-500",
    label: "Apresentação",
  },
  award: {
    icon: "award",
    color: "text-amber-700",
    bg: "bg-amber-50",
    borderColor: "border-l-amber-500",
    iconBg: "bg-amber-500",
    label: "Premiação",
  },
  social: {
    icon: "users",
    color: "text-pink-700",
    bg: "bg-pink-50",
    borderColor: "border-l-pink-500",
    iconBg: "bg-pink-500",
    label: "Encerramento",
  },
};
---

<section id="cronograma" class="bg-white">
  <div class="py-20 px-4 sm:px-6 max-w-5xl mx-auto">
    <div class="mb-10">
      <h2 class="text-slate-900 text-3xl font-bold mb-2">Cronograma</h2>
      <p class="text-slate-600">09 a 11 de setembro de 2026 • IFES Serra</p>
    </div>

    <div class="flex gap-2 mb-8">
      {
        schedule.map((d, i) => (
          <button
            data-day={i}
            class="day-tab px-5 py-2 rounded-lg border transition-colors bg-white border-slate-200 text-slate-600 hover:border-slate-300 text-sm font-medium"
          >
            {d.dayName} • {d.date}
          </button>
        ))
      }
    </div>

    <div id="type-legend" class="flex flex-wrap gap-2 mb-8">
      {
        dayTypes[0].map((type) => {
          const cfg = typeConfig[type];
          return (
            <span
              data-type={type}
              class={`flex items-center gap-2 px-3 py-1.5 rounded-lg ${cfg.bg} border border-slate-200 type-legend-item`}
            >
              <div class={`w-3 h-3 rounded ${cfg.iconBg}`} />
              <span class={`text-xs font-medium ${cfg.color}`}>{cfg.label}</span>
            </span>
          );
        })
      }
    </div>

    {
      schedule.map((day, dayIndex) => (
        <div
          data-day-content={dayIndex}
          class={`day-content ${dayIndex !== 0 ? "hidden" : ""}`}
        >
          <div class="space-y-2">
            {day.activities.map((activity, i) => {
              const cfg = typeConfig[activity.type];
              const isBreak = activity.type === "break";
              return (
                <div
                  data-type={activity.type}
                  class={`schedule-item flex gap-3 p-4 rounded-lg border-l-4 ${cfg.borderColor} border border-slate-200 ${cfg.bg} ${isBreak ? "opacity-60" : ""}`}
                >
                  <div class="flex-shrink-0 w-14">
                    <span
                      class={`font-mono text-sm font-semibold ${cfg.color}`}
                    >
                      {activity.time}
                    </span>
                  </div>
                  <div
                    class={`flex-shrink-0 w-8 h-8 rounded-lg ${cfg.iconBg} flex items-center justify-center`}
                  >
                    <svg
                      class="w-4 h-4 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      {activity.type === "break" && <Coffee size={23} />}
                      {(activity.type === "opening" ||
                        activity.type === "talk") && <MicVocal size={23} />}
                      {(activity.type === "social" ||
                        activity.type === "poster") && <Users size={23} />}
                      {activity.type === "award" && <Award size={23} />}
                      {activity.type === "workshop" && <Book size={23} />}
                      {activity.type === "lab" && <FlaskConical size={23} />}
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2">
                      <div class="flex-1">
                        <p class={`text-sm font-semibold ${cfg.color}`}>
                          {activity.title}
                        </p>
                        {activity.speaker && (
                          <p class="text-slate-700 text-xs mt-1">
                            {activity.speaker}
                          </p>
                        )}
                        {activity.location && (
                          <p class="text-slate-600 text-xs mt-0.5">
                            📍 {activity.location}
                          </p>
                        )}
                      </div>
                      <span
                        class={`px-2 py-1 rounded text-xs font-medium whitespace-nowrap ${cfg.color} hidden sm:block`}
                      >
                        {cfg.label}
                      </span>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))
    }

    <p class="text-center text-slate-500 text-xs mt-8">
      * Programação sujeita a pequenas alterações. Acompanhe nossas redes
      sociais.
    </p>
  </div>
</section>

<script>
  const dayTabs = document.querySelectorAll(".day-tab");
  const dayContents = document.querySelectorAll(".day-content");
  const typeLegend = document.getElementById("type-legend")!;

  // Type config for legend updates
  const typeConfigMap = {
    opening: { bg: "bg-violet-50", bgActive: "bg-violet-100", iconBg: "bg-violet-500", color: "text-violet-700", colorActive: "text-violet-900", label: "Abertura" },
    talk: { bg: "bg-blue-50", bgActive: "bg-blue-100", iconBg: "bg-blue-500", color: "text-blue-700", colorActive: "text-blue-900", label: "Palestra" },
    break: { bg: "bg-emerald-50", bgActive: "bg-emerald-100", iconBg: "bg-emerald-500", color: "text-emerald-700", colorActive: "text-emerald-900", label: "Intervalo" },
    poster: { bg: "bg-cyan-50", bgActive: "bg-cyan-100", iconBg: "bg-cyan-500", color: "text-cyan-700", colorActive: "text-cyan-900", label: "Apresentação" },
    award: { bg: "bg-amber-50", bgActive: "bg-amber-100", iconBg: "bg-amber-500", color: "text-amber-700", colorActive: "text-amber-900", label: "Premiação" },
    social: { bg: "bg-pink-50", bgActive: "bg-pink-100", iconBg: "bg-pink-500", color: "text-pink-700", colorActive: "text-pink-900", label: "Encerramento" }
  } as const;

  type EventType = keyof typeof typeConfigMap;

  // Day types data embedded as JSON
  const dayTypes: EventType[][] = [
    ["opening", "talk", "break", "poster", "social"],
    ["talk", "poster", "break", "award", "social"],
    ["talk", "poster", "break", "social"]
  ];

  // Active type filters (can have multiple)
  const activeFilters: Set<EventType> = new Set();
  let currentDayIndex = 0;

  function updateLegend(dayIndex: number) {
    const types: EventType[] = dayTypes[dayIndex];
    currentDayIndex = dayIndex;
    typeLegend.innerHTML = types.map(type => {
      const cfg = typeConfigMap[type];
      const isActive = activeFilters.has(type);
      const bgClass = isActive ? cfg.bgActive : cfg.bg;
      const colorClass = isActive ? cfg.colorActive : cfg.color;
      return `<button data-type="${type}" class="flex items-center gap-2 px-3 py-1.5 rounded-lg ${bgClass} border border-slate-200 type-legend-item transition-colors ${isActive ? 'ring-2 ring-offset-1 ring-' + cfg.iconBg.replace('bg-', '') : ''}">
        <div class="w-3 h-3 rounded ${cfg.iconBg}"></div>
        <span class="text-xs font-medium ${colorClass}">${cfg.label}</span>
      </button>`;
    }).join("");

    // Re-attach click handlers
    typeLegend.querySelectorAll(".type-legend-item").forEach(btn => {
      btn.addEventListener("click", () => {
        const type = btn.getAttribute("data-type") as EventType;
        if (activeFilters.has(type)) {
          activeFilters.delete(type);
        } else {
          activeFilters.add(type);
        }
        updateLegend(currentDayIndex);
        filterSchedule();
      });
    });
  }

  function filterSchedule() {
    dayContents.forEach((content, idx) => {
      if (idx !== currentDayIndex) return;
      const items = content.querySelectorAll(".schedule-item");
      items.forEach(item => {
        const itemType = item.getAttribute("data-type") as EventType;
        if (activeFilters.size === 0 || activeFilters.has(itemType)) {
          item.classList.remove("hidden");
        } else {
          item.classList.add("hidden");
        }
      });
    });
  }

  dayTabs.forEach((tab, index) => {
    tab.addEventListener("click", () => {
      dayTabs.forEach((t) => {
        t.classList.remove("bg-blue-600", "border-blue-600", "text-white");
        t.classList.add("bg-white", "border-slate-200", "text-slate-600");
      });
      tab.classList.add("bg-blue-600", "border-blue-600", "text-white");
      tab.classList.remove("bg-white", "border-slate-200", "text-slate-600");

      dayContents.forEach((content) => {
        content.classList.add("hidden");
      });
      const activeContent = document.querySelector(
        `[data-day-content="${index}"]`,
      );
      activeContent?.classList.remove("hidden");

      updateLegend(index);
      filterSchedule();
    });
  });

  // Set initial active state for first tab
  if (dayTabs[0]) {
    dayTabs[0].classList.add("bg-blue-600", "border-blue-600", "text-white");
    dayTabs[0].classList.remove(
      "bg-white",
      "border-slate-200",
      "text-slate-600",
    );
  }

  // Initialize legend with click handlers and filter
  updateLegend(0);
  filterSchedule();
</script>
