  },
  {
    name: "Eduardo Marino",
    affil: "UFRJ",
    topic: "Teoria para a Supercondutividade de Alta Temperatura em Cupratos.",
    tag: "Teoria Quântica de Campos",
    curriculumUrl: "http://lattes.cnpq.br/4256849386217726",
    imageRef: marinoImg.src,
  },
  {
    name: "Geanderson Carvalho",
    affil: "UTFPR/UFES",
