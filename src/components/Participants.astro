---

<section id="palestrantes" class="bg-gradient-to-b from-slate-50 to-blue-50/30">
  <div class="py-20 px-4 sm:px-6 max-w-7xl mx-auto">
    <div class="mb-12">
      <h2 class="text-slate-900 text-3xl font-bold mb-2">Palestrantes</h2>
      <p class="text-slate-600">
        Pesquisadores de diferentes instituições do país
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-16">
      {
        speakers.map((speaker) => (
          <div class="bg-white border border-slate-200 rounded-lg overflow-hidden">
            <div class="relative h-67">
              <img
                src={speaker.imageRef}
                alt={speaker.name}
                class="w-full h-full object-cover object-center"
              />
              <span class="absolute top-2 right-2 px-2 py-1 bg-white text-slate-700 text-xs rounded font-medium">
                {speaker.affil}
              </span>
              <a
                href={speaker.curriculumUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="absolute bottom-2 right-2 px-2 py-2 text-blue-600 bg-background/88 border border-blue-600 text-sm gap-1 flex rounded-full">
                  <ExternalLink size={18} /> Abrir Currículo
                </span>
              </a>
            </div>
            <div class="p-4">
              <p class="text-xs text-blue-600 mb-1">{speaker.tag}</p>
              <h3 class="text-slate-900 font-semibold mb-2">{speaker.name}</h3>
              <div class="border-t border-slate-200 pt-2 mt-2">
                <p class="text-slate-600 text-sm leading-snug">
                  {speaker.topic}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div>
      <div class="mb-8">
        <h3 class="text-slate-900 text-xl font-bold mb-1">Organização</h3>
        <p class="text-slate-500 text-sm">Comitê organizador do evento</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {
          committeeMembers.map((member, i) => (
            <div class="flex items-center gap-3 p-3 bg-white border border-slate-200 rounded-lg">
              {/* <div class="w-9 h-9 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0"> */}
              <Avatar src={member.image} size={36} />
              {/* </div> */}
              <div>
                <p class="text-slate-900 text-sm font-medium">{member.name}</p>
                <p class="text-slate-600 text-xs">{member.role}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
