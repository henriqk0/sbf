---
import Layout from "../layouts/Layout.astro";

const accommodations = [
  {
    name: "Serra Lindo Hotel",
    address: "Rua dos Uirapurús, 559 - Morada de Laranjeiras, Serra - ES",
    distance: "1,3 km do IFES Serra",
    phone: "(27) 3338-7538",
    email: "reservas@serralindahotel.com.br",
    maps: "https://www.google.com/maps/place/Serra+Linda+Hotel/@-20.1979645,-40.2260667,17z/data=!3m1!4b1!4m9!3m8!1s0xb81eb67f0233a1:0x83525ed353cfccbf!5m2!4m1!1i2!8m2!3d-20.1979645!4d-40.2260667!16s%2Fg%2F11f_b_80c2?entry=ttu&g_ep=EgoyMDI2MDUxMC4wIKXMDSoASAFQAw%3D%3D",
  },
  {
    name: "Serra Grande - Hotel & Churrascaria",
    address:
      "Av. Eldes Scherrer Souza, 870, Parque Residencial Laranjeiras, Serra - ES",
    distance: "4,5 km do IFES Serra",
    phone: "(27) 2125-5200",
    email: "reservas@gruposerragrande.com.br",
    maps: "https://www.google.com/maps/place/Serra+Grande+-+Hotel+%26+Churrascaria/@-20.193839,-40.2524337,17z/data=!3m1!4b1!4m9!3m8!1s0xb81ee9856fb2bd:0x733b588338341149!5m2!4m1!1i2!8m2!3d-20.193839!4d-40.2524337!16s%2Fg%2F1tcyb41s?entry=ttu&g_ep=EgoyMDI2MDUxMC4wIKXMDSoASAFQAw%3D%3D",
  },
  {
    name: "Hotel Jardins",
    address: "Hotel Jardins, ES-010, 1307 - Jardim Limoeiro, Serra - ES",
    distance: "5,4 km do IFES Serra",
    phone: "(27) 99782-8769",
    email: "reservas@statuselegancehotel.com.br",
    maps: "https://www.google.com/maps/place/Hotel+Jardins/data=!4m2!3m1!1s0x0:0x40e73bb25fb12b9b?sa=X&ved=1t:2428&ictx=111",
  },
  {
    name: "Transamerica Fit Serra",
    address: "Av. Des. Mário da Silva Nunes, 738 - Jardim Limoeiro, Serra - ES",
    distance: "6,1 km do IFES Serra",
    phone: "(27) 3180-0223",
    email: "reservas.tfse@ahi.com.br",
    maps: "https://www.google.com/maps/place/Transamerica+Fit+Serra/data=!4m2!3m1!1s0xb8192b43da243d:0xd8ed0d3845d94a62?sa=X&ved=1t:242&ictx=111",
  },
];
---

<Layout title="Hospedagem – ECF/SBF 2026">
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <h1 class="text-slate-900 text-3xl font-bold mb-3">Hospedagem</h1>
        <p class="text-slate-600 max-w-2xl">
          Sugestões de hotéis e pousadas próximos ao local do evento
        </p>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-12">
        <p class="text-sm text-slate-700">
          <strong>Importante:</strong> As acomodações listadas são sugestões. O ECF/SBF
          não possui convênio oficial com nenhum estabelecimento. Recomendamos entrar
          em contato diretamente para verificar disponibilidade e valores.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {
          accommodations.map((acc) => (
            <div class="bg-white border border-slate-200 rounded-lg p-6 w-full flex flex-col">
              <h3 class="text-slate-900 font-semibold mb-3">{acc.name}</h3>

              <div class="space-y-2 text-sm flex-1">
                <div class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-slate-500 flex-shrink-0 mt-0.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  <div>
                    <p class="text-slate-900">{acc.address}</p>
                    <p class="text-slate-500">{acc.distance}</p>
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4 text-slate-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"
                    />
                  </svg>
                  <a
                    href={`tel:${acc.phone.replace(/\D/g, "")}`}
                    class="text-blue-600 hover:underline"
                  >
                    {acc.phone}
                  </a>
                </div>

                <div class="flex items-center gap-2 mb-3">
                  <svg
                    class="w-4 h-4 text-slate-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                  <a
                    href={`mailto:${acc.email}`}
                    class="text-blue-600 hover:underline text-xs"
                  >
                    {acc.email}
                  </a>
                </div>
              </div>

              <a
                href={acc.maps}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-auto flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors text-sm"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-navigation w-4 h-4"
                  data-fg-ywq23="7.17:7.3481:/src/app/components/Location.tsx:41:17:1940:34:e:Navigation::::::too"
                  data-fgid-ywq23=":r3v:"
                >
                  <polygon points="3 11 22 2 13 21 11 13 3 11" />
                </svg>
                Abrir no Google Maps
              </a>
            </div>
          ))
        }
      </div>

      <div class="bg-slate-50 border border-slate-200 rounded-lg p-6">
        <h3 class="text-slate-900 font-semibold mb-4">Outras Opções</h3>
        <p class="text-slate-600 text-sm mb-3">
          Você também pode buscar acomodações em plataformas como:
        </p>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://www.airbnb.com.br"
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:underline"
            >
              • Airbnb - Apartamentos e casas na região
            </a>
          </li>
          <li>
            <a
              href="https://www.booking.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:underline"
            >
              • Booking.com - Hotéis e pousadas
            </a>
          </li>
          <li>
            <a
              href="https://www.trivago.com.br"
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:underline"
            >
              • Trivago - Comparador de preços de hotéis
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
