---
import Layout from "../layouts/Layout.astro";

const accommodations = [
  {
    name: "Serra Lindo Hotel",
    address: "Rua dos Uirapurus, 559, Morada de Laranjeiras Serra/ES ",
    distance: "720 m do IFES Serra",
    phone: "(27)3338-7538",
    email: "reservas@serralindahotel.com.br",
  },
  {
    name: "Serra Grande - Hotel & Churrascaria",
    address: "Av. Eldes Scherrer Souza, 870, Parque Residencial Laranjeiras. Serra - ES, 29165-680",
    distance: "4,5 km do IFES Serra",
    phone: "(27) 2125-5200",
    email: "reservas@gruposerragrande.com.br",
  },  
  {
    name: "Hotel Jardins",
    address:
      "Hotel Jardins, ES-010, 1307 - Jardim Limoeiro, Serra - ES, 29164-140",
    distance: "6 km do IFES Serra",
    phone: "(27) 99782-8769",
    email: "reservas@statuselegancehotel.com.br",
  },
  {
    name: "Go Inn Serra",
    address:
      "Go Inn Serra - Av. Des. Mário da Silva Nunes, 738 - Jardim Limoeiro, Serra - ES, 29164-044",
    distance: "7 km do IFES Serra",
    phone: "(27) 3180-0223",
    email: "reservas.tfse@ahi.com.br",
  },
];
---

<Layout title="Hospedagem – ECF/SBF 2026">
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <h1 class="text-slate-900 text-3xl font-bold mb-3">Hospedagem</h1>
        <p class="text-slate-600 max-w-2xl">
          Sugestões de hotéis e pousadas próximos ao local do evento
        </p>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-12">
        <p class="text-sm text-slate-700">
          <strong>Importante:</strong> As acomodações listadas são sugestões. O ECF/SBF
          não possui convênio oficial com nenhum estabelecimento. Recomendamos entrar
          em contato diretamente para verificar disponibilidade e valores.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {
          accommodations.map((acc) => (
            <div class="bg-white border border-slate-200 rounded-lg p-6 w-full">
              <h3 class="text-slate-900 font-semibold mb-3">{acc.name}</h3>

              <div class="space-y-2 text-sm">
                <div class="flex items-start gap-2">
                  <svg
                    class="w-4 h-4 text-slate-500 flex-shrink-0 mt-0.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  <div>
                    <p class="text-slate-900">{acc.address}</p>
                    <p class="text-slate-500">{acc.distance}</p>
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4 text-slate-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"
                    />
                  </svg>
                  <a
                    href={`tel:${acc.phone.replace(/\D/g, "")}`}
                    class="text-blue-600 hover:underline"
                  >
                    {acc.phone}
                  </a>
                </div>

                <div class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4 text-slate-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                  <a
                    href={`mailto:${acc.email}`}
                    class="text-blue-600 hover:underline text-xs"
                  >
                    {acc.email}
                  </a>
                </div>
                <a
                  href="https://www.google.com/maps/place/IFES+-+Campus+Serra/@-20.1976491,-40.2202422,17z/data=!3m1!4b1!4m6!3m5!1s0xb81de52407d8d7:0x289693da8d05dd09!8m2!3d-20.1976491!4d-40.2176673!16s%2Fg%2F11gyc3xq80?entry=ttu&g_ep=EgoyMDI2MDQyNi4wIKXMDSoASAFQAw%3D%3D"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors text-sm"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-navigation w-4 h-4" data-fg-ywq23="7.17:7.3481:/src/app/components/Location.tsx:41:17:1940:34:e:Navigation::::::too" data-fgid-ywq23=":r3v:"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>Abrir no Google Maps
                </a>
              </div>
            </div>
          ))
        }
      </div>

      <div class="bg-slate-50 border border-slate-200 rounded-lg p-6">
        <h3 class="text-slate-900 font-semibold mb-4">Outras Opções</h3>
        <p class="text-slate-600 text-sm mb-3">
          Você também pode buscar acomodações em plataformas como:
        </p>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://www.airbnb.com.br"
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:underline"
            >
              • Airbnb - Apartamentos e casas na região
            </a>
          </li>
          <li>
            <a
              href="https://www.booking.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:underline"
            >
              • Booking.com - Hotéis e pousadas
            </a>
          </li>
          <li>
            <a
              href="https://www.trivago.com.br"
              target="_blank"
              rel="noopener noreferrer"
              class="text-blue-600 hover:underline"
            >
              • Trivago - Comparador de preços de hotéis
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
